{
  "name": "pvmd",
  "version": "0.1.0",
  "description": "Terminal-launched Markdown previewer that renders in the browser with live reload and GitHub-style rendering.",
  "license": "MIT",
  "author": "Andrej Milanović",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "pvmd": "dist/index.js"
  },
  "keywords": [
    "markdown",
    "preview",
    "browser",
    "cli",
    "terminal",
    "live-reload",
    "github-markdown"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrejcode/pvmd.git"
  },
  "homepage": "https://github.com/andrejcode/pvmd#readme",
  "bugs": {
    "url": "https://github.com/andrejcode/pvmd/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node dev.js",
    "dev:app": "NODE_ENV=development tsx src/index.ts",
    "dev:client": "node esbuild.client.dev.js",
    "clean": "rm -rf dist .dev-build",
    "build": "npm run build:app && npm run build:client",
    "build:app": "npm run typecheck:app && node esbuild.config.js",
    "build:client": "npm run typecheck:client && node esbuild.client.js",
    "typecheck": "npm run typecheck:app && npm run typecheck:client",
    "typecheck:app": "tsc --noEmit --project tsconfig.app.json",
    "typecheck:client": "tsc --noEmit --project tsconfig.client.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:app": "vitest run --project app",
    "test:client": "vitest run --project client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@wooorm/starry-night": "^3.9.0",
    "gemoji": "^8.1.0",
    "github-markdown-css": "^5.9.0",
    "hast-util-to-html": "^9.0.5",
    "marked": "^17.0.3",
    "marked-alert": "^2.1.2",
    "marked-emoji": "^2.0.2",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.3",
    "marked-highlight": "^2.2.3",
    "marked-katex-extension": "^5.1.7",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
