{
  "name": "pvmd",
  "version": "0.0.0",
  "description": "",
  "license": "MIT",
  "author": "Andrej Milanović",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pvmd": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run typecheck && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:node:* --minify && npm run copy:client",
    "copy:client": "mkdir -p dist/client && cp src/client/index.html dist/client/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.6.2",
    "@types/sanitize-html": "^2.16.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "marked": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.4",
    "xss": "^1.0.15"
  }
}
