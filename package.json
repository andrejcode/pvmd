{
  "name": "pvmd",
  "version": "0.0.0",
  "description": "",
  "license": "MIT",
  "author": "Andrej Milanović",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pvmd": "dist/index.js"
  },
  "scripts": {
    "dev": "node dev.js",
    "dev:app": "NODE_ENV=development tsx src/index.ts",
    "dev:client": "node esbuild.client.dev.js",
    "clean": "rm -rf dist .dev-build",
    "build": "npm run clean && npm run build:app && npm run build:client",
    "build:app": "npm run typecheck:app && node esbuild.config.js",
    "build:client": "npm run typecheck:client && node esbuild.client.js",
    "typecheck": "npm run typecheck:app && npm run typecheck:client",
    "typecheck:app": "tsc --noEmit --project tsconfig.app.json",
    "typecheck:client": "tsc --noEmit --project tsconfig.client.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:app": "vitest run --project app",
    "test:client": "vitest run --project client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "github-markdown-css": "^5.8.1",
    "marked": "^17.0.1",
    "marked-alert": "^2.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.6.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.4"
  }
}
